<comment>
coordinate_system = cartesian

<job>
problem_id = 2DMHDHelioCartesianSMRcp2ch8  # problem ID: basename of output filenames

<output1>
file_type  = hdf5      # Binary data dump
variable   = prim      # variables to be output
dt         = 10        # time increment between outputs
id         = prim      # filename

<time>
cfl_number = 0.5       # The Courant, Friedrichs, & Lewy (CFL) Number
nlim       = -1        # cycle limit
tlim       = 500       # time limit
integrator = vl2       # time integration algorithm
xorder     = 2         # order of spatial reconstruction
ncycle_out = 1         # interval for stdout summary info

<mesh>
nx1        = 64           # Number of zones in X1-direction
x1min      = -360          # minimum value of X1
x1max      = 240           # maximum value of X1
ix1_bc     = outflow       # inner-X1 boundary flag
ox1_bc     = user          # outer-X1 boundary flag  

nx2        = 64       
x2min      = -300              
x2max      = 300            
ix2_bc     = outflow      # inner-X2 boundary flag
ox2_bc     = outflow      # outer-X2 boundary flag

nx3        = 2
x3min      = -100
x3max      = 100
ix3_bc     = outflow     # inner-X2 boundary flag
ox3_bc     = outflow     # outer-X2 boundary flag

refinement        = static
numlevel          = 4
derefine_count    = 5

<meshblock>
nx1 = 32
nx2 = 32
nx3 = 2

<refinement1>
x1min = -40
x1max = 40
x2min = -40
x2max = 40
x3min = -40
x3max = 40
level = 3

<hydro>
gamma = 1.666666666666667 # gamma = C_p/C_v
cp_glm = 2.0  #parabolic (damping) dvergence parameter for Dedner cleaning (should be greater than ch, damping ~ ch^2/cp^2)
ch_glm = 8.0 #hyperbolic (wave carrying) divergence parameter for Dedner cleaning
flag_dedner_source = true #NEEDS TO BE TRUE IN ORDER TO ENABLE SOURCE TERM TO EVOLVE PSI FOR DEDNER CLEANING

<problem>
ism_dens = 0.1 #cm-3
ism_temp = 6530.0 #K
ism_vel = 26.53 #km/s
ism_B = 0 #nT 
angle_ism_lambda = 3.92699 #radians
angle_ism_beta = 0.663225 #radians
angle_ism = 0
omega = 2.8e-6
radius_swBC = 1.0 #AU
sw_densBC = 5.0 #cm-3, 1AU
sw_tempBC = 100000.0 #K, 1AU
sw_velBC = 400.0 #km/s, assume constant solar wind velocity within termination shock
sw_bBC = 5.0 #nT, 5.0 is the normal 1AU value
r_inner = 20.0 #AU
threshold_densGrad = 0.4 #AMR Parameter (should be fractional changes in values, i.e. if we want to refine when a quantity changes by a factor of 2 across a cell, set this to 1.0, if we want a factor of 3, 2.0, etc )
deref_threshold_densGrad = 0.2 #AMR Parameter
threshold_tempGrad = 0.5 #AMR Parameter
deref_threshold_tempGrad = 0.25 #AMR Parameter
threshold_pressGrad = 0.5 #AMR Parameter
deref_threshold_pressGrad = 0.25 #AMR Parameter